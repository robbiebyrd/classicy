{
  "main": "./dist/classicy.umd.js",
  "module": "./dist/classicy.es.js",
  "types": "./dist/types/src/index.d.ts",
  "name": "classicy",
  "version": "0.6.46",
  "repository": {
    "type": "git",
    "url": "https://github.com/robbiebyrd/classicy"
  },
  "type": "module",
  "description": "A UI framework in React, replicating the user interface of Classic MacOS 8 (called Platinum).",
  "keywords": [
    "react",
    "typescript",
    "nextjs",
    "platinum",
    "macos-classic",
    "typescript-react"
  ],
  "author": "Robbie Byrd <me@robbiebyrd.com>",
  "license": "Unlicense",
  "scripts": {
    "generate-barrels": "barrelsby --delete -c .ts-barrel.json --location all --noHeader",
    "dev": "npm run build:source && npm link",
    "build": "npm run build:audio && npm run build:source",
    "build:source": "npm run generate-barrels && tsc -b && vite build",
    "build:audio": "./bin/make_audio_sprites.sh",
    "build:watch": "concurrently --kill-others \"npm run build:watchaudio\" \"npm run build:watchsource\"",
    "build:watchaudio": "nodemon --watch \"resources/sounds/**\" --ext \"mp3,mp4,wav,aif,aiff,ogg,flac,m4a,ac3,json\" --exec \"npm run build:audio\" --ignore \"example/**\" ",
    "build:watchsource": "nodemon --watch \"src/**\" --watch \"assets/**\" --ext \"tsx,ts,json,css,scss,png,jpg,svg\" --exec \"tsc -b && vite build\" --ignore \"example/**\" --ignore \"**/index.ts\" --ignore \"**/index\\ *.ts\" --ignore \"**/index\\ *.tsx\" ",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "npm run build && npm link && cd example && npm i && npm link classicy && npm run build && npm run dev"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/classicy.es.js",
      "require": "./dist/classicy.umd.js"
    },
    "./dist/*": "./dist/*.js"
  },
  "dependencies": {
    "@analytics/google-tag-manager": "^0.6.0",
    "@mdxeditor/editor": "^3.52.1",
    "@plussub/srt-vtt-parser": "^2.0.5",
    "@tanstack/react-table": "^8.21.3",
    "analytics": "^0.8.19",
    "classnames": "^2.5.1",
    "he": "^1.2.0",
    "howler": "^2.2.4",
    "immer": "^11.1.4",
    "react-json-tree": "^0.20.0",
    "react-player": "^3.4.0",
    "screenfull": "^6.0.2",
    "sha512-crypt-ts": "^0.1.27",
    "use-analytics": "^1.1.0",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@analytics/google-analytics": "^1.1.0",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@eslint/js": "^9.39.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/he": "^1.2.3",
    "@types/howler": "^2.2.12",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/use-analytics": "^0.0.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "barrelsby": "^2.8.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^29.0.1",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sass": "^1.97.3",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-image-tools": "^3.1.1",
    "vite-plugin-react-rich-svg": "^1.3.0",
    "vitest": "^4.1.1"
  },
  "volta": {
    "node": "24.12.0"
  }
}
